    "@hermes-os/context-graph": "workspace:*",
    "@hermes-os/memory": "workspace:*",
    "@hermes-os/notification-center": "workspace:*",
    "@hermes-os/research": "workspace:*",
    "@hermes-os/policies": "workspace:*",
    "@hermes-os/risk-engine": "workspace:*",
    "@hermes-os/shared": "workspace:*",
    "@hermes-os/tool-executor": "workspace:*",
    "@hermes-os/workflows": "workspace:*",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
