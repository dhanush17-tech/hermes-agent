# Personal OS
HERMES_OS_ROOT=/path/to/hermes-personal-os
DATABASE_PATH=./data/local.sqlite
APPROVAL_TTL_SECONDS=300
APPROVED_IMESSAGE_SENDERS=["+15551234567","you@example.com"]
# Required: Hermes only replies to this number/email (and APPROVED_IMESSAGE_SENDERS). OTP/bank SMS are ignored.
IMESSAGE_DEFAULT_RECIPIENT=+15551234567
IMESSAGE_POLL_MS=3000
# Proactive daemon (Arc presence scans off by default — see configs/autonomy-policy.yaml)
PROACTIVE_SCAN_INTERVAL_MS=900000
PROACTIVE_STARTUP_GRACE_MS=300000
# HERMES_ENABLE_PRESENCE_SCAN=1
# HERMES_DISABLE_PRESENCE_SCAN=1
PROACTIVE_MORNING_BRIEF_HOUR=7
PROACTIVE_EVENING_REVIEW_HOUR=21

# Google OAuth — run: node scripts/google-oauth.mjs
# GOOGLE_OAUTH_CLIENT_PATH=~/.hermes/secrets/google-oauth-client.json
# GOOGLE_OAUTH_TOKEN_PATH=~/.hermes/secrets/google-oauth-tokens.json
# GMAIL_ACCESS_TOKEN=   # optional override; token file preferred
# Model for iMessage / web chat (avoid GLM chain-of-thought leaking into replies)
# HERMES_MESSAGING_MODEL=@cf/meta/llama-3.2-3b-instruct
# HERMES_CHAT_PORT=3847 (agents + tools → SQLite + data/activity.jsonl)
# HERMES_ACTIVITY_CONSOLE=1
# HERMES_ACTIVITY_JSONL=0

# Laptop control — browser engine: playwright (default) or arc
HERMES_BROWSER_ENGINE=playwright
# HERMES_DISABLE_CHAT=1
# HERMES_ENABLE_IMESSAGE=1
# HERMES_CDP_ENDPOINT=http://127.0.0.1:9222
# HERMES_STAGEHAND_ENABLED=1
# HERMES_STAGEHAND_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Multi-account Gmail (connector-first)
# GOOGLE_ACCOUNTS='[{"id":"personal","email":"you@gmail.com","tokenPath":"~/.hermes/secrets/google-token-personal.json"}]'

# Hermes Python gateway (coding + code.self_edit)
HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=your-api-server-key-from-hermes-env

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_workers_ai_token
CLOUDFLARE_AI_BASE_URL=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1

# Laptop control — Arc is the default browser on macOS
HERMES_DEFAULT_BROWSER=Arc

# Optional: force headless HTTP fetch for browser_task (default is screen + open URL in Arc)
# HERMES_HEADLESS_FETCH=1

# Supermemory — semantic memory (https://supermemory.ai/docs/memory-api/)
SUPERMEMORY_API_KEY=sm_your_key_from_app_supermemory_ai
SUPERMEMORY_CONTAINER_TAG=hermes_default_user
# SUPERMEMORY_PROJECT=hermes-personal-os
# MEMORY_INJECTION_ENABLED=1
# MEMORY_CAPTURE_ENABLED=1
